# Copy to `.env` (at repo root) and fill in. `.env` is gitignored — never commit keys.

# --- Option A: OpenAI (default) ---
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini          # optional override

# --- Option B: OpenRouter (free models, no OpenAI credit needed) ---
# Get a key at https://openrouter.ai/keys . With only this key set, it's used automatically.
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free   # any ":free" slug works

# Force a provider explicitly (otherwise auto-picked): openai | openrouter
# LLM_PROVIDER=openrouter
